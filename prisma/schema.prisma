generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum VideoPublishStatus {
  READY
  PUBLISHING
  FAILED
}

model Video {
  id          String    @id @default(cuid())
  title       String
  description String
  videoUrl    String
  r2Key       String?
  lastUsedAt  DateTime?

  publishStatus VideoPublishStatus @default(READY)
  publishingAt DateTime?
  publishError String?
  instagramMediaId String?
  instagramPermalink String?
}

model Upload {
  id               String   @id @default(uuid())
  title            String
  description      String
  originalFileName String
  storedFileName   String   @unique
  storedPath       String
  mimeType         String
  sizeBytes        Int
  status           String
  facebookVideoId  String?
  publishStatus    String   @default("not_published")
  publishError     String?
  createdAt        DateTime @default(now())
}

model Pokemon {
  id String @id @default(cuid())
  name String 
  type String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
